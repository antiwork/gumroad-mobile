ANDROID_BUNDLE_NAME=com.antiwork.gumroadmobile
IOS_BUNDLE_NAME=com.antiwork.gumroadmobile

EXPO_PUBLIC_GUMROAD_URL=https://gumroad.dev
EXPO_PUBLIC_GUMROAD_API_URL=https://api.gumroad.dev
EXPO_PUBLIC_GUMROAD_CLIENT_ID=MOBILE_DEVELOPMENT_CLIENT_kx3sRpN217qPwqk9s
EXPO_PUBLIC_MOBILE_TOKEN=development-mobile-token

# Expo doesn't sync the Sign in with Apple capability correctly
EXPO_NO_CAPABILITY_SYNC=1

# We don't upload source maps locally, and the lack of Sentry credentials can cause the iOS dev build to fail
SENTRY_ALLOW_FAILURE=true
